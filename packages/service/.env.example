# === AgentPay Service Configuration ===

# Database
DATABASE_URL=postgres://agentpay:agentpay@localhost:5433/agentpay

# Admin authentication (required)
# Used for dashboard/CLI access to admin endpoints
AGENTPAY_ADMIN_KEY=change-me-to-a-real-secret

# Server
PORT=3456

# === Signing Provider ===
# Options: "local" (dev/testing), "para" (production)
SIGNING_PROVIDER=local

# Para (fka Capsule) — required when SIGNING_PROVIDER=para
# Get keys at https://developer.getpara.com
PARA_API_KEY=
PARA_ENVIRONMENT=sandbox
# "sandbox" → https://api.beta.getpara.com
# "production" → https://api.getpara.com

# === Chain RPCs (optional — uses public RPCs if not set) ===
# Format: RPC_<CHAIN_ID>=<url>  (dots replaced with underscores)
RPC_EIP155_1=
RPC_EIP155_8453=
RPC_EIP155_42161=
RPC_EIP155_10=
RPC_EIP155_137=
RPC_SOLANA_MAINNET=
STELLAR_HORIZON_URL=
STELLAR_SOROBAN_RPC_URL=
